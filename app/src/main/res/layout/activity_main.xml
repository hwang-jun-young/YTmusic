<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YTmusic"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF" />

    <View
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:layout_marginTop="8dp"
        android:background="#FF4444" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        app:cardBackgroundColor="#141420"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center">

            <TextView
                android:id="@+id/statusIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸"
                android:textSize="64sp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="시작 버튼을 눌러주세요"
                android:textSize="16sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5" />

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="20dp"
                android:indeterminate="true"
                android:progressTint="#FF4444"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 연결 시작 + 취소 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="▶  연결 시작"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF4444"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="80dp"
            android:layout_height="64dp"
            android:layout_marginStart="8dp"
            android:text="취소"
            android:textSize="14sp"
            android:textColor="#FF4444"
            android:backgroundTint="#1E1E2E"
            android:stateListAnimator="@null"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 수동 실행 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="수동 실행"
        android:textSize="12sp"
        android:textColor="#555555" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnOpenVpn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="🔒 WireGuard"
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#1E1E2E"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnMorf"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🎵 모프"
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#1E1E2E"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
